{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "allowSyntheticDefaultImports": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "dist/main",
    "rootDir": "src/main",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/main/**/*.ts"]
}
