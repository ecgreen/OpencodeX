{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "allowSyntheticDefaultImports": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "dist/preload",
    "rootDir": "src/preload",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/preload/**/*.ts"]
}
