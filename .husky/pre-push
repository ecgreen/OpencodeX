#!/bin/sh
set -e

if [ -n "$(git status --porcelain -- graphify-out .graphifyignore)" ]; then
  echo "[graphify] graphify-out has uncommitted changes. Commit the graphify artifacts before pushing." >&2
  git status --short -- graphify-out .graphifyignore >&2
  exit 1
fi

echo "husky - skipping local typecheck; GitHub Actions validates pushes and PRs"
