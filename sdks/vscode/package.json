{
  "name": "opencodex",
  "displayName": "OpencodeX",
  "description": "OpencodeX for VS Code",
  "version": "0.0.1",
  "publisher": "ecgreen",
  "repository": {
    "type": "git",
    "url": "https://github.com/ecgreen/OpencodeX"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#000000",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "opencodex.openTerminal",
        "title": "OpencodeX: Open OpencodeX",
        "icon": {
          "light": "images/button-dark.png",
          "dark": "images/button-light.png"
        }
      },
      {
        "command": "opencodex.openNewTerminal",
        "title": "OpencodeX: Open OpencodeX in New Tab",
        "icon": {
          "light": "images/button-dark.png",
          "dark": "images/button-light.png"
        }
      },
      {
        "command": "opencodex.addFilepathToTerminal",
        "title": "OpencodeX: Add Filepath to Terminal"
      }
    ],
    "configuration": {
      "title": "OpencodeX",
      "properties": {
        "opencodex.command": {
          "type": "string",
          "default": "opencodex",
          "description": "Shell command used to launch the OpencodeX TUI. For local testing this can be a wrapper command, for example a WSL command."
        },
        "opencodex.arguments": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed before --port when launching OpencodeX."
        },
        "opencodex.autoAttachCurrentFile": {
          "type": "boolean",
          "default": true,
          "description": "Automatically append the active file reference when opening OpencodeX."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "opencodex.openNewTerminal",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "opencodex.openTerminal",
        "title": "Run OpencodeX",
        "key": "cmd+escape",
        "mac": "cmd+escape",
        "win": "ctrl+escape",
        "linux": "ctrl+escape"
      },
      {
        "command": "opencodex.openNewTerminal",
        "title": "Run OpencodeX",
        "key": "cmd+shift+escape",
        "mac": "cmd+shift+escape",
        "win": "ctrl+shift+escape",
        "linux": "ctrl+shift+escape"
      },
      {
        "command": "opencodex.addFilepathToTerminal",
        "title": "OpencodeX: Insert At-Mentioned",
        "key": "cmd+alt+k",
        "mac": "cmd+alt+k",
        "win": "ctrl+alt+K",
        "linux": "ctrl+alt+K"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node -e \"require('fs').existsSync('dist/extension.js') || process.exit(1)\"",
    "compile": "bun run check-types && bun run lint && node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "bun run check-types && bun run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "bun run compile-tests && bun run compile && bun run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.94.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
